# Environment Variables for Entropy Prime

# ──────────────────────────────────────────────────────────────────────────────
# MongoDB Configuration (for docker-compose.prod.yml)
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB root username (production)
MONGO_USER=entropy

# MongoDB root password (generate with: openssl rand -hex 24)
MONGO_PASSWORD=change_me_to_random_mongodb_password_hex_24

# MongoDB URI (auto-constructed in docker-compose.prod.yml)
MONGODB_URI=mongodb://entropy:changeme@mongodb:27017/entropy_prime?authSource=admin

# Database name
MONGODB_DB_NAME=entropy_prime

# ──────────────────────────────────────────────────────────────────────────────
# Redis Configuration (for caching, session state)
# ──────────────────────────────────────────────────────────────────────────────

# Redis password (generate with: openssl rand -hex 24)
REDIS_PASSWORD=change_me_to_random_redis_password_hex_24

# Redis URI (auto-constructed in docker-compose.prod.yml)
REDIS_URI=redis://:changeme@redis:6379/0

# ──────────────────────────────────────────────────────────────────────────────
# Backend Secrets (Auto-generated if not set)
# IMPORTANT: Generate with: openssl rand -hex 64
# ──────────────────────────────────────────────────────────────────────────────

# HMAC key for real session tokens (64 hex chars = 32 bytes)
EP_SESSION_SECRET=change_me_to_random_secret_key_64_hex_chars_minimum_required

# HMAC key for API key signing (same as SESSION_SECRET for development)
EP_API_KEY_SECRET=change_me_to_random_secret_key_64_hex_chars_minimum_required

# HMAC key for JWT (admin dashboard auth)
JWT_SECRET=change_me_to_random_secret_key_64_hex_chars_minimum_required

# HMAC key for synthetic honeypot tokens (shadow mode)
SHADOW_SECRET=change_me_to_random_shadow_secret_key_64_hex_chars_minimum_required

# CORS Allowed Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3001

# Domain for production (used by docker-compose.prod.yml)
NGINX_HOST=localhost
EP_DOMAIN=localhost

# ──────────────────────────────────────────────────────────────────────────────
# RL Model Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Path to pre-trained DQN checkpoint (Governor)
EP_RL_CHECKPOINT=./checkpoints/governor.pt

# Path to Multi-Armed Bandit checkpoint
EP_MAB_CHECKPOINT=./checkpoints/mab.json

# Path to PPO checkpoint (Watchdog)
EP_PPO_CHECKPOINT=./checkpoints/watchdog.pt

# ──────────────────────────────────────────────────────────────────────────────
# Backend Server Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Server host and port
HOST=0.0.0.0
PORT=8000

# Number of worker processes (uvicorn)
EP_WORKERS=4

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
EP_LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────────
# Frontend Configuration
# ──────────────────────────────────────────────────────────────────────────────

# API URL for frontend
VITE_API_URL=http://localhost:8000

# Frontend port (used by vite during development)
VITE_PORT=3000

# ──────────────────────────────────────────────────────────────────────────────
# Production Docker Configuration (for docker-compose.prod.yml)
# ──────────────────────────────────────────────────────────────────────────────

# Data root directory for persistent volumes
DATA_ROOT=./data

# TLS certificate paths (for Nginx in docker-compose.prod.yml)
# Map to ./nginx/ssl/cert.pem and ./nginx/ssl/key.pem
NGINX_CERT_PATH=/etc/nginx/ssl/cert.pem
NGINX_KEY_PATH=/etc/nginx/ssl/key.pem

# Feature flags for production
ENABLE_WEBHOOKS=true
ENABLE_THREAT_INTEL=true
ENABLE_CROSS_SITE_GATING=true