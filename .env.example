# Environment Variables for Entropy Prime

# Core auth / security
EP_SESSION_SECRET=change_me_to_random_64_hex_chars
EP_API_KEY_SECRET=change_me_to_random_64_hex_chars
JWT_SECRET=change_me_to_random_64_hex_chars
SHADOW_SECRET=change_me_to_random_64_hex_chars
EP_JWT_PUBLIC_KEY_PATH=keys/public.pem
EP_JWT_AUDIENCE=entropy-prime-admin
ENVIRONMENT=development

# MongoDB / Redis
MONGO_USER=entropy
MONGO_PASSWORD=change_me_to_random_mongodb_password_hex_24
MONGODB_URL=mongodb://entropy:${MONGO_PASSWORD}@mongodb:27017/entropy_prime?authSource=admin
MONGODB_DB_NAME=entropy_prime
REDIS_PASSWORD=change_me_to_random_redis_password_hex_24
REDIS_URI=redis://:${REDIS_PASSWORD}@redis:6379/0

# CORS / domain
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3001
NGINX_HOST=localhost
EP_DOMAIN=localhost

# RL model checkpoints
EP_CHECKPOINT_DIR=./checkpoints
EP_RL_CHECKPOINT=./checkpoints/governor.pt
EP_MAB_CHECKPOINT=./checkpoints/mab.json
EP_GOV_PPO_CHECKPOINT=./checkpoints/governor_ppo.pt
EP_PPO_CHECKPOINT=./checkpoints/watchdog.pt

# Backend server
HOST=0.0.0.0
PORT=8000
EP_WORKERS=4
EP_LOG_LEVEL=INFO
LOG_LEVEL=INFO
WORKERS=4
DEBUG=False

# Frontend
VITE_API_URL=http://localhost:8000
VITE_PORT=3000

# Feature flags
ENABLE_WEBHOOKS=true
ENABLE_THREAT_INTEL=true
ENABLE_CROSS_SITE_GATING=true

# Production paths
DATA_ROOT=./data
NGINX_CERT_PATH=/etc/nginx/ssl/cert.pem
NGINX_KEY_PATH=/etc/nginx/ssl/key.pem