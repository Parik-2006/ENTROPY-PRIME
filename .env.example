# Environment Variables for Entropy Prime

# ──────────────────────────────────────────────────────────────────────────────
# MongoDB Configuration
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB Connection URL
# For MongoDB Atlas (Cloud): mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
# For Local MongoDB: mongodb://localhost:27017
MONGODB_URL=mongodb+srv://entropy_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name
MONGODB_DB_NAME=entropy_prime

# ──────────────────────────────────────────────────────────────────────────────
# Backend Secrets (Auto-generated if not set)
# ──────────────────────────────────────────────────────────────────────────────

# HMAC key for real session tokens
EP_SESSION_SECRET=change_me_to_random_secret_key_32_chars_min

# HMAC key for synthetic honeypot tokens (shadow mode)
EP_SHADOW_SECRET=change_me_to_random_shadow_secret_key

# ──────────────────────────────────────────────────────────────────────────────
# RL Model Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Path to pre-trained DQN checkpoint (optional)
# Generate with: python backend/train.py --episodes 100000 --out ../checkpoints/governor.pt
EP_RL_CHECKPOINT=./checkpoints/governor.pt

# ──────────────────────────────────────────────────────────────────────────────
# Frontend Configuration
# ──────────────────────────────────────────────────────────────────────────────

# API URL for frontend (optional, used in production)
VITE_API_URL=http://localhost:8000

# Frontend port (used by vite)
VITE_PORT=3000
